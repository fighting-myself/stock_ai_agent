# 复制为 .env 后填写。变量名须与 config/settings.py 中字段一致。

# ---------------- 模型 API KEY ----------------
DASHSCOPE_API_KEY=
DOUBAO_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
OPENAI_API_KEY=

# ---------------- vLLM（OpenAI 兼容网关，可选）----------------
VLLM_BASE_URL=
VLLM_MODEL=
VLLM_API_KEY=EMPTY

# ---------------- 默认行为 ----------------
DEFAULT_MODEL=qwen3-vl-plus
DEFAULT_AGENT_TYPE=react

# ---------------- Tushare ----------------
TUSHARE_TOKEN=

# ---------------- 股票数据与超时 ----------------
EASTMONEY_API_TIMEOUT=10
STOCK_RETRY_MAX=3

# ---------------- 同花顺 iFinD QuantAPI（可选）----------------
THS_IFIND_REFRESH_TOKEN=
THS_IFIND_BASE_URL=https://quantapi.51ifind.com
THS_IFIND_TIMEOUT=45
THS_IFIND_WENCAI_SEARCH_TYPE=stock
THS_IFIND_REPORT_TYPE=901

# ---------------- 服务 ----------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
LOG_LEVEL=INFO

# ---------------- 前端（仅 Streamlit 读取，不进 Settings）----------------
BACKEND_URL=http://localhost:8001
